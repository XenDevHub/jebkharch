# ─────────────────────────────────────────────
# Database (PostgreSQL via Docker Compose)
# ─────────────────────────────────────────────
DB_USER=jebkharch
DB_PASSWORD=jebkharch_dev
DB_NAME=jebkharch_db
DB_PORT=5432
DB_HOST=localhost
DATABASE_URL="postgresql://jebkharch:jebkharch_dev@localhost:5432/jebkharch_db?schema=public"

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# NestJS API
# ─────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# JWT Auth
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_here_change_in_prod
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# OpenAI (server-side ONLY — never expose to client)
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────
# SMS Provider (Pakistani gateway)
# TODO: Replace MockSmsProvider with real provider
# e.g. Jazz/Telenor/Zong SMS API credentials
# ─────────────────────────────────────────────
SMS_PROVIDER=mock
# SMS_API_KEY=your_sms_gateway_api_key
# SMS_SENDER_ID=JEBKHARCH

# ─────────────────────────────────────────────
# Easypaisa Payout Provider
# TODO: Replace MockPayoutProvider with real Easypaisa merchant API
# ─────────────────────────────────────────────
PAYOUT_PROVIDER=mock
# EASYPAISA_MERCHANT_ID=your_merchant_id
# EASYPAISA_MERCHANT_KEY=your_merchant_key
# EASYPAISA_API_URL=https://easypay.easypaisa.com.pk/tpg/

# ─────────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# For S3-compatible:
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=jebkharch-uploads
# AWS_S3_REGION=ap-south-1
# AWS_S3_ENDPOINT=https://s3.amazonaws.com

# ─────────────────────────────────────────────
# Subscription Provider
# TODO: Replace MockSubscriptionProvider with JazzCash/Easypaisa recurring billing
# ─────────────────────────────────────────────
SUBSCRIPTION_PROVIDER=mock
SUBSCRIPTION_PRICE_PKR=150

# ─────────────────────────────────────────────
# Ad Provider
# TODO: Replace MockAdProvider with AdMob SDK in mobile app
# ─────────────────────────────────────────────
AD_PROVIDER=mock
# ADMOB_APP_ID=ca-app-pub-xxxx
# ADMOB_REWARDED_UNIT_ID=ca-app-pub-xxxx/yyyy

# ─────────────────────────────────────────────
# CORS / Frontend URLs
# ─────────────────────────────────────────────
ADMIN_PANEL_URL=http://localhost:5173
MOBILE_DEEP_LINK_SCHEME=jebkharch

# ─────────────────────────────────────────────
# Fraud / Security
# ─────────────────────────────────────────────
MAX_OTP_ATTEMPTS=5
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
WITHDRAWAL_LARGE_AMOUNT_THRESHOLD=1000
DAILY_COIN_EARNING_CAP=50
DAILY_AD_WATCH_CAP=10
WITHDRAWAL_COOLDOWN_HOURS=24
MIN_WITHDRAWAL_COINS=500
